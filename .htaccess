Options -Indexes
DirectoryIndex index.html

RewriteEngine On

RewriteCond %{THE_REQUEST} \s/+%D0%B3%D0%BE%D0%BB%D0%BE%D0%B2%D0%BD%D0%B0-%D1%81%D1%82%D0%BE%D1%80%D1%96%D0%BD%D0%BA%D0%B0/?(?:[?\s]|$) [NC]
RewriteRule ^ / [R=301,L,NE]

RewriteCond %{THE_REQUEST} \s/+%D0%BF%D0%BE%D1%81%D0%BB%D1%83%D0%B3%D0%B8/?(?:[?\s]|$) [NC]
RewriteRule ^ /services/ [R=301,L,NE]

RewriteCond %{THE_REQUEST} \s/+%D1%86%D1%96%D0%BD%D0%B8/?(?:[?\s]|$) [NC]
RewriteRule ^ /prices/ [R=301,L,NE]

RewriteCond %{THE_REQUEST} \s/+%D0%BF%D1%80%D0%BE-%D0%BD%D0%B0%D1%81/?(?:[?\s]|$) [NC]
RewriteRule ^ /about/ [R=301,L,NE]

RewriteCond %{THE_REQUEST} \s/+%D0%BA%D0%BE%D0%BD%D1%82%D0%B0%D0%BA%D1%82%D0%BD%D0%B0-%D1%96%D0%BD%D1%84%D0%BE%D1%80%D0%BC%D0%B0%D1%86%D1%96%D1%8F/?(?:[?\s]|$) [NC]
RewriteRule ^ /contacts/ [R=301,L,NE]

RewriteCond %{THE_REQUEST} \s/+%D0%B2%D1%96%D0%B4%D0%B3%D1%83%D0%BA%D0%B8/?(?:[?\s]|$) [NC]
RewriteRule ^ /#reviews [R=301,L,NE]

RewriteRule ^головна-сторінка/?$ / [R=301,L,NE]
RewriteRule ^послуги/?$ /services/ [R=301,L,NE]
RewriteRule ^ціни/?$ /prices/ [R=301,L,NE]
RewriteRule ^про-нас/?$ /about/ [R=301,L,NE]
RewriteRule ^контактна-інформація/?$ /contacts/ [R=301,L,NE]
RewriteRule ^відгуки/?$ /#reviews [R=301,L,NE]
